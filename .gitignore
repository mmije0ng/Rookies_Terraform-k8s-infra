# Terraform working directories and generated files
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform variable files can contain local or sensitive values
*.tfvars
*.tfvars.json
!*.tfvars.example

# Terraform plan outputs
*.tfplan
plan.out

# Override files are usually local-only
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock files from editors and operating systems
.DS_Store
Thumbs.db
*.swp
*.swo

# Local IDE settings
.idea/
.vscode/
